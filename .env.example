# =================================================================
# Copy this file to `.env` and fill in real keys.
# Do NOT commit `.env` to git -- it is in .gitignore.
# =================================================================

# --- Default provider routing ------------------------------------
# The agent uses src/llm.py to route OpenAI-compatible calls. To switch
# provider per call, prefix MODEL / EMBED_MODEL with `<provider>:`. A
# bare slug (no colon) uses LLM_DEFAULT_PROVIDER below.
#
# Examples:
#     MODEL=openai/gpt-4o-mini                  -> default provider
#     MODEL=groq:llama-3.3-70b-versatile        -> Groq
#     MODEL=nim:meta/llama-3.3-70b-instruct     -> NVIDIA NIM
#     EMBED_MODEL=nim:nvidia/nv-embedqa-e5-v5   -> NIM 1024-dim embeddings

LLM_DEFAULT_PROVIDER=openrouter
MODEL=openai/gpt-4o-mini
EMBED_MODEL=openai/text-embedding-3-small

# --- OpenRouter (chat + embeddings) ------------------------------
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- Groq (chat only, very fast) ---------------------------------
# https://console.groq.com/keys  --  no embeddings endpoint
# GROQ_API_KEY=gsk_your-key-here

# --- NVIDIA NIM (chat + embeddings) ------------------------------
# https://build.nvidia.com  --  embed model is 1024-dim, requires
# wiping .chroma/ and re-running scripts.ingest if you switch to it.
# NIM_API_KEY=nvapi-your-key-here

# --- Tavily (real web search for the web_search tool) ------------
# https://app.tavily.com/  --  src/tools.py falls back to canned data
# when this key is missing, so it is optional.
# TAVILY_API_KEY=tvly-your-key-here

# --- Legacy OpenAI direct (optional fallback) --------------------
# Used by src/llm.py only if the provider-specific key above is missing.
# OPENAI_API_KEY=sk-your-key-here
